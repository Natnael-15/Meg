<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for V8 (Electron's JS engine needs this) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (V8 / Chromium requirement) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow dyld env vars (needed for Electron helper processes) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access — Meg talks to LM Studio (localhost) + cloud LLM providers -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File system access — Meg reads/writes workspace files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Disable sandbox so Meg can spawn child processes (MCP servers, PowerShell/cmd, git) -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
