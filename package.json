{
  "name": "meg",
  "version": "1.0.0-beta.2",
  "description": "Meg — The Local AI Operating System",
  "author": "Natnael-15",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron . --enable-logging\"",
    "renderer:dev": "vite --host 127.0.0.1",
    "renderer:build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "electron . --enable-logging",
    "build": "npm run renderer:build && electron-builder build --win --publish never",
    "release": "npm run renderer:build && electron-builder build --win --publish always"
  },
  "build": {
    "appId": "com.meg.ai",
    "productName": "Meg",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icons/meg-icon.ico",
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Natnael-15",
        "repo": "Meg"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "openai": "^4.91.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^35.1.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
